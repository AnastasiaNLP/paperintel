# Required for LLM-assisted analysis and QA.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider and model selection.
LLM_PROVIDER=anthropic
OPENAI_MODEL=gpt-4o-mini
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# Optional tracing. Disable for local tests unless you explicitly want LangSmith traces.
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=paperintel

# Optional enrichment.
GITHUB_TOKEN=

# Local durable storage defaults used by docker-compose.yml.
POSTGRES_URL=postgresql://paperintel:dev_password@localhost:5432/paperintel
DATABASE_URL=postgresql://paperintel:dev_password@localhost:5432/paperintel

# Vector retrieval.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=paper_chunks
QDRANT_TIMEOUT=10

# Opt-in test services.
PAPERINTEL_TEST_DATABASE_URL=postgresql+psycopg://paperintel:dev_password@localhost:5432/paperintel
PAPERINTEL_QDRANT_TEST_URL=http://localhost:6333
